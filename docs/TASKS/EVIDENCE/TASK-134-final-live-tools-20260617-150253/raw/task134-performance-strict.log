             or metadata::text like 'TASK134_FINAL_PERF_RERUN_PERFORMANCE_STRICT_%'
             or entity_ids::text like 'TASK134_FINAL_PERF_RERUN_PERFORMANCE_STRICT_%'
          returning 1
        ),
        deleted_products as (
          delete from public.inventory_products p
          using target_products t
          where p.id = t.id
          returning 1
        ),
        deleted_categories as (
          delete from public.inventory_categories
